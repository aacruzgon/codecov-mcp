# codecov-mcp environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains secrets.

# --- Required ---

# Your Codecov API token. Generate one at https://app.codecov.io/account/gh/<owner>/api
# Keep this secret: it grants read access to all repos visible to your account.
CODECOV_TOKEN=your_codecov_token_here

# The GitHub/GitLab/Bitbucket organization or username that owns the repository.
CODECOV_OWNER=your_org_or_username

# The repository name (without the owner prefix).
CODECOV_REPO=your_repo_name

# --- Optional ---

# Version control service. One of: github, gitlab, bitbucket (default: github)
CODECOV_SERVICE=github

# Codecov API base URL. Override only if using a self-hosted Codecov instance.
CODECOV_BASE_URL=https://api.codecov.io

# Maximum number of polling retries when waiting for coverage to become available.
CODECOV_MAX_RETRIES=5

# Delay in milliseconds between polling retries.
CODECOV_POLL_DELAY_MS=2000

# Log verbosity. Set to debug for troubleshooting.
RUST_LOG=info
